. $HOME/setup/setup_def.bash
alias ta="tmux -2 attach"
alias master="ssh -p ${HOME_SSH_PORT} ${HOME_USER_NAME}@${HOME_SSH_HOST}"

if [[ $HOME_SESSION_TYPE != "remote/ssh" && "$(whoami)" != 'incus-root' && "$(whoami)" != 'root' ]]; then
    # keyboard carret speed
    xset r rate 250 28

    # don't sleep monitor
    xset s off
    xset -dpms
    xset s noblank

    # switching the keyboard layout
    setxkbmap "us,$HOME_SECOND_KEYBOARD_LAYOUT" ",winkeys" "grp:win_space_toggle"

    # background color
    xsetroot -solid "#333333"
fi

# tmux
export TERM="screen-256color"
alias tmux="tmux -2"

# fzf + rg
export FZF_DEFAULT_COMMAND='rg --files --no-ignore -g "!{.git,node_modules,vendor}/*" 2> /dev/null'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
if [ -t 1 ]
then
  bind -x '"\C-p": fzf_path=$(fzf); vim $fzf_path; history -s vim $fzf_path'
fi


# incus
alias incus='sudo incus'
alias iil='incus image list -c lfpdts'
alias il='incus list -c ns4tS'
alias ir='sudo -u incus-root -i'

# navigation
alias pp='f(){ echo "$(pwd)/$1"; }; f'
alias gcal='gcal -s1'

# git
alias gs='git status'
alias gf='git diff'
alias ga='git add .'
gi() {
    if [[ $# -lt 3 ]]; then
        echo "usage: gi <type> <scope> <message...>"
        return 1
    fi

    local type="$1"
    local scope="$2"
    shift 2
    local msg="$*"

    # add → feat
    if [[ "$type" == "add" ]]; then
        type="feat"
    fi

    git commit -m "${type}(${scope}): ${msg}"
}

# vibe coding
alias vpn='proxychains4 -q -f ~/.proxychains.conf bash --rcfile ~/.vpnrc'
o() {
    if [ "$VPN_ACTIVE" != "1" ]; then
        echo "❗ opencode can only be run inside a VPN session. Run 'vpn' first."
        return 1
    fi
    opencode --agent plan "$@"
}

# Add VPN prefix to prompt if inside VPN shell
# IMPORTANT: must be at the end of the file
if [ "$VPN_ACTIVE" = "1" ]; then
    PS1="[VPN] $PS1"
fi
